<?xml version="1.0" encoding="utf-8"?>
<!--
   Exclude shared_prefs from auto-backup.
   - shared_prefs: EncryptedSharedPreferences (server URL, credentials).
   - database: kept excluded as defense-in-depth (no longer strictly required
     since remove-message-persistence Task 6 deleted chat_cache.db, but
     harmless and stable).
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
</full-backup-content>
